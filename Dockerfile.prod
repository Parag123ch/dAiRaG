FROM node:23-alpine AS frontend-build

WORKDIR /app/frontend

COPY dAiRaG/frontend/package.json dAiRaG/frontend/package-lock.json ./
RUN npm ci

COPY dAiRaG/frontend ./
RUN npm run build

FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1     PYTHONUNBUFFERED=1     DAIRAG_SERVE_FRONTEND=true     HOST=0.0.0.0     PORT=8000

WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY dAiRaG /app/dAiRaG
COPY dataset /app/dataset
COPY --from=frontend-build /app/frontend/dist /app/dAiRaG/frontend/dist

WORKDIR /app/dAiRaG

EXPOSE 8000

CMD ["python", "run_server.py"]
