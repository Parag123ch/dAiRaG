# NVIDIA
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_CYPHER_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_ANSWER_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=0.95
DISABLE_NVIDIA_CYPHER_CHAT=false

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_CYPHER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_ANSWER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_TOP_P=0.9
OPENROUTER_APP_TITLE=dAiRAG
OPENROUTER_HTTP_REFERER=
DISABLE_OPENROUTER_CYPHER_CHAT=false

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CYPHER_MODEL=gemini-2.5-flash
GEMINI_ANSWER_MODEL=gemini-2.5-flash
DISABLE_GEMINI_CYPHER_CHAT=false

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_CYPHER_MODEL=gpt-5-mini
OPENAI_ANSWER_MODEL=gpt-5-mini
OPENAI_BASE_URL=
DISABLE_LLM_CYPHER_CHAT=false

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_TIMEOUT_SECONDS=8
